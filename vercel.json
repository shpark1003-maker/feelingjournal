{
  "version": 2,
  "cleanUrls": true,
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/",
      "destination": "/public/index.html"
    },
    {
      "source": "/(style.css|app.js|manifest.json|sw.js|icon-512.png)",
      "destination": "/public/$1"
    }
  ]
}
